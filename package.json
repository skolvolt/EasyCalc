{
  "name": "quotemodel",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite web",
    "build": "vite build web",
    "build:server": "esbuild src/server/index.ts --bundle --platform=node --format=esm --outfile=package-build/app/server.mjs --packages=external",
    "package": "npm run build && npm run build:server && node scripts/assemble-package.mjs",
    "server": "tsx src/server/index.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/static": "^8.0.0",
    "fastify": "^5.2.0",
    "playwright-core": "^1.61.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "xlsx-js-style": "^1.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "esbuild": "^0.28.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vitest": "^2.1.8"
  }
}
